{
  "skill_id": "french_tuck",
  "name": "法式半塞",
  "name_en": "French Tuck",
  "difficulty": 1,
  "estimated_time_seconds": 10,
  "headline": "把T恤前摆塞进裤腰一点点",
  "description": "将上衣前摆中间部分塞入裤腰约3-5cm，后摆自然垂放。只塞前不塞后，制造不经意的松弛感。",
  "steps": [
    "站直，找到上衣前摆正中间位置（肚脐正前方）",
    "只塞正前方约5cm宽的一小块，轻拉出约1cm松量",
    "塞进裤腰约3-5cm，让前摆微微鼓出一点弧度，后摆自然垂下不塞"
  ],
  "why_it_works": "明确腰线位置，打破'上宽下宽'的H型轮廓。视觉上把上半身截短，腿就从腰线开始算，立刻拉长比例。",
  "expected_effect": "腿长视觉+10-15%，整体更利落，有'随便穿但很好看'的松弛感",
