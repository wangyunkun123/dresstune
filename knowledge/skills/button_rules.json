  "rules": {
    "单穿衬衫": {
      "unbutton": 2,
      "note": "解开最上面两颗，制造V领效果"
    },
    "内搭衬衫（外套里）": {
      "unbutton": 1,
      "note": "解开最上面一颗，比全扣多一分随意"
    },
    "Polo衫单穿": {
      "unbutton": 2,
      "note": "Polo领口设计就是为解开两颗穿的"
    },
    "Polo衫全扣": {
      "note": "极少见，除非运动场合防领口翻飞"
    },
    "正式场合（打领带）": {
      "unbutton": 0,
      "note": "全扣，最正式"
    },
    "半正式（不系领带）": {
      "unbutton": 1,
      "note": "解一颗，不显紧绷"
    }
  },
  "common_mistakes": [
    "衬衫解三颗以上 → 太暴露轻浮。正确做法：最多两颗",
    "内搭全扣 → 像第一天上班。正确做法：内搭解一颗更自然",
    "Polo衫全扣到顶 → 非常老气。正确做法：Polo设计就是为解开穿",
    "解扣后领子歪斜 → 邋遢。正确做法：整理领型对称"
  ],
